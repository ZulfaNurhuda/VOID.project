# =============================================
# VOID CONFIGURATION — PRODUCTION
Copy to .env and fill in real values. NEVER commit .env!
# =============================================

# ── PostgreSQL Container ─────────────────────
POSTGRES_DB=void_db
POSTGRES_USER=void_user
POSTGRES_PASSWORD=change_me_to_secure_password
POSTGRES_INITDB_ARGS=--encoding=UTF8 --locale=en_US.UTF-8

# ── Database Connection ───────────────────────
DB_HOST=void-postgres
DB_PORT=5432
DB_NAME=void_db
DB_USER=void_user
DB_PASSWORD=change_me_to_secure_password
DB_SSLMODE=disable

# ── Redis Connection ──────────────────────────
REDIS_HOST=void-redis
REDIS_PORT=6379
# REDIS_PASSWORD=   # uncomment if Redis requires auth

# ── Auth ─────────────────────────────────────
# Generate with: openssl rand -base64 64
SESSION_SECRET=change_me_to_long_random_secret_at_least_64_chars

# ── JWT ──────────────────────────────────────
JWT_SECRET=change_me_to_secure_jwt_secret
# JWT_PRIVATE_KEY will be set by patch_env.py on homeserver

# ── OAuth Providers (optional) ────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ── SMTP (optional — for password reset & invite emails) ─
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# ── Instance ──────────────────────────────────
VOID_BASE_URL=http://localhost:38271
API_HOST=http://localhost:38271
ENVIRONMENT=production
VOID_MANAGED=false

# ── General ───────────────────────────────────
COMPOSE_PROJECT_NAME=void
